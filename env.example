# ==================== Core ====================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TZ=Asia/Seoul

# ==================== Database ====================
DATABASE_URL=postgresql://layer:layer_dev@localhost:5432/layer_studio

# ==================== Claude API ====================
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
CLAUDE_TIMEOUT_MS=60000

# ==================== Supertone Play (Korean TTS) ====================
# Voice clone is created in the Supertone Play web UI, then referenced here by ID.
SUPERTONE_API_KEY=xxx
SUPERTONE_API_BASE=https://supertoneapi.com
SUPERTONE_VOICE_ID_KO=xxx
SUPERTONE_MODEL=sona_speech_1
SUPERTONE_LANGUAGE=ko
SUPERTONE_STYLE=neutral
SUPERTONE_PITCH_SHIFT=0
SUPERTONE_PITCH_VARIANCE=1
SUPERTONE_SPEED=1
SUPERTONE_TIMEOUT_MS=120000
SUPERTONE_RATE_LIMIT_PER_MIN=20
SUPERTONE_CREDIT_WARN_THRESHOLD=10000

# ==================== Pexels ====================
PEXELS_API_KEY=xxx
PEXELS_PER_PAGE=15
PEXELS_TIMEOUT_MS=10000

# ==================== YouTube Data API ====================
YOUTUBE_CLIENT_ID=xxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxx
YOUTUBE_REFRESH_TOKEN_AI=xxx
YOUTUBE_REFRESH_TOKEN_SKIN=xxx
YOUTUBE_CHANNEL_ID_AI=UCxxx
YOUTUBE_CHANNEL_ID_SKIN=UCxxx

# ==================== Notion ====================
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID_AI=xxx
NOTION_DATABASE_ID_SKIN=xxx

# ==================== Slack ====================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
SLACK_CHANNEL=#layer-studio

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=layer-studio-assets

# ==================== RSS Feeds ====================
RSS_FEEDS_AI=https://techcrunch.com/category/artificial-intelligence/feed/,https://www.theverge.com/rss/index.xml,https://www.anthropic.com/rss
RSS_FEEDS_SKIN=https://www.allure.com/feed/rss
