generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Channel ====================

enum Channel {
  AI
  SKIN
}

// ==================== News ====================

model NewsItem {
  id          String   @id @default(cuid())
  channel     Channel
  title       String
  description String?  @db.Text
  url         String   @unique
  source      String
  publishedAt DateTime
  fetchedAt   DateTime @default(now())

  titleHash   String   @unique

  selected    Boolean  @default(false)

  // Source language of the news item — affects curation + script generation
  sourceLang  String   @default("ko") // "ko" | "en"

  videos      Video[]

  @@index([channel, publishedAt])
  @@index([fetchedAt])
}

// ==================== Video ====================

enum VideoStatus {
  PENDING
  READY
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

// Content delivery template — see docs/FORMATS.md.
// A: Informational (new product / feature announcement)
// C: How-to (practical tutorial with screen demo)
enum VideoFormat {
  A
  C
}

model Video {
  id               String       @id @default(cuid())
  channel          Channel
  format           VideoFormat?
  status           VideoStatus  @default(PENDING)

  // Korean script + metadata (channel is Korean-only; foreign viewers rely on
  // YouTube auto-translation of the uploaded Korean caption track)
  titleKo          String
  scriptKo         String      @db.Text
  descriptionKo    String?     @db.Text
  tags             String[]

  // Subtitle timing data: sentence-level Korean text with start/end seconds
  subtitleSegments Json?

  newsItemId       String?
  newsItem         NewsItem?   @relation(fields: [newsItemId], references: [id])

  // Assets
  videoUrl         String?
  thumbnailUrl     String?
  audioUrl         String?     // Korean narration (Supertone generated)
  subtitleUrl      String?     // Korean SRT file (YouTube caption track)

  // TTS metadata (Supertone)
  ttsProvider      String      @default("supertone")
  ttsVoiceId       String?
  ttsCredits       Int?        // Credits consumed (monitoring)
  ttsDurationSec   Float?      // Total audio duration in seconds

  // YouTube
  youtubeVideoId   String?
  publishedAt      DateTime?
  scheduledAt      DateTime?

  // Notion
  notionPageId     String?

  // Analytics
  viewCount        Int         @default(0)
  likeCount        Int         @default(0)
  commentCount     Int         @default(0)
  lastAnalyzedAt   DateTime?

  // Error tracking
  errorLog         String?     @db.Text
  retryCount       Int         @default(0)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  assets           VideoAsset[]

  @@index([channel, status])
  @@index([status, createdAt])
  @@index([publishedAt])
}

// ==================== Video Assets ====================

enum AssetType {
  B_ROLL
  IMAGE
  AUDIO_NARRATION_KO    // Korean narration generated by Supertone
  AUDIO_BGM
  SUBTITLE_SRT_EN       // English SRT subtitle file
  SUBTITLE_DATA         // Sentence-level timing JSON
}

model VideoAsset {
  id        String    @id @default(cuid())
  videoId   String
  video     Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)

  type      AssetType
  url       String
  metadata  Json

  order     Int       @default(0)

  createdAt DateTime  @default(now())

  @@index([videoId, type])
}

// ==================== Pipeline Runs ====================

enum PipelineStep {
  NEWS_FETCH
  NEWS_CURATE
  SCRIPT_GENERATE_KO
  BROLL_FETCH
  TTS_GENERATE_KO
  SUBTITLE_GENERATE_KO
  VIDEO_RENDER
  NOTION_CREATE
  SLACK_NOTIFY
  APPROVAL
  YOUTUBE_UPLOAD
  YOUTUBE_CAPTION_UPLOAD
}

enum StepStatus {
  STARTED
  SUCCESS
  FAILED
  SKIPPED
}

model PipelineRun {
  id        String    @id @default(cuid())
  channel   Channel
  videoId   String?

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  status    String

  logs      PipelineLog[]

  @@index([channel, startedAt])
}

model PipelineLog {
  id            String       @id @default(cuid())
  runId         String
  run           PipelineRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  step          PipelineStep
  status        StepStatus
  message       String?      @db.Text
  metadata      Json?

  startedAt     DateTime     @default(now())
  durationMs    Int?

  @@index([runId, step])
}

// ==================== Cost Tracking ====================

model ApiCost {
  id         String   @id @default(cuid())
  service    String   // "claude" | "supertone" | "pexels" | ...
  endpoint   String?

  tokensIn   Int?
  tokensOut  Int?
  charCount  Int?
  credits    Int?     // Supertone credits consumed

  cost       Decimal  @db.Decimal(10, 4)

  videoId    String?
  createdAt  DateTime @default(now())

  @@index([service, createdAt])
}
