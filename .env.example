# ========== Core ==========
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TZ=Asia/Seoul
# Local Postgres (via docker-compose or brew). Required for Prisma to boot.
DATABASE_URL=postgresql://layer:layer_dev@localhost:5433/layer_studio
# Set to "true" in prod/staging to enable the KST 19:00 cron run for both channels.
# Default false so local dev boots don't trigger unattended API-spending runs.
PIPELINE_CRON_ENABLED=false

# ========== Claude (Anthropic) ==========
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT_MS=60000

# ========== Supertone Play (Korean TTS) ==========
# Issue API key at https://console.supertoneapi.com
SUPERTONE_API_KEY=
SUPERTONE_API_BASE=https://supertoneapi.com
# Clone voice ID from Supertone Play web UI (https://supertone.ai/ko/play)
SUPERTONE_VOICE_ID_KO=
SUPERTONE_MODEL=sona_speech_2
SUPERTONE_LANGUAGE=ko
# Leave empty for custom (cloned) voices — the voice itself defines its style.
# Set only for stock voices that support multiple styles (e.g. "neutral", "warm").
SUPERTONE_STYLE=
SUPERTONE_PITCH_SHIFT=0
SUPERTONE_PITCH_VARIANCE=1
SUPERTONE_SPEED=1
SUPERTONE_TIMEOUT_MS=60000
# API rate limit: 20 requests per minute
SUPERTONE_RATE_LIMIT_PER_MIN=20
# Alert when monthly credit usage exceeds this threshold (Creator plan: 100,000/mo)
SUPERTONE_CREDIT_WARN_THRESHOLD=80000

# ========== Pexels ==========
PEXELS_API_KEY=
PEXELS_PER_PAGE=15
PEXELS_TIMEOUT_MS=10000

# ========== YouTube Data API ==========
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_AI=
YOUTUBE_REFRESH_TOKEN_SKIN=
YOUTUBE_CHANNEL_ID_AI=
YOUTUBE_CHANNEL_ID_SKIN=

# ========== Notion ==========
NOTION_API_KEY=
NOTION_DATABASE_ID_AI=
NOTION_DATABASE_ID_SKIN=

# ========== Slack ==========
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#layer-studio

# ========== AWS S3 ==========
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=layer-studio-assets

# ========== RSS Feeds ==========
RSS_FEEDS_AI=https://techcrunch.com/category/artificial-intelligence/feed/,https://www.theverge.com/rss/index.xml
RSS_FEEDS_SKIN=https://www.allure.com/feed/rss
