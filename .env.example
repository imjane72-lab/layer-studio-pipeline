# ========== Core ==========
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
TZ=Asia/Seoul

# Local Postgres (via docker-compose or brew). Required for Prisma to boot.
DATABASE_URL=postgresql://layer:layer_dev@localhost:5433/layer_studio

# ========== Claude (Anthropic) ==========
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001
CLAUDE_MODEL_SONNET=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TIMEOUT_MS=60000

# ========== ElevenLabs ==========
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_TIMEOUT_MS=120000

# ========== Pexels ==========
PEXELS_API_KEY=
PEXELS_PER_PAGE=15
PEXELS_TIMEOUT_MS=10000

# ========== YouTube Data API ==========
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN_AI=
YOUTUBE_REFRESH_TOKEN_SKIN=
YOUTUBE_CHANNEL_ID_AI=
YOUTUBE_CHANNEL_ID_SKIN=

# ========== Notion ==========
NOTION_API_KEY=
NOTION_DATABASE_ID_AI=
NOTION_DATABASE_ID_SKIN=

# ========== Slack ==========
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#layer-studio

# ========== AWS S3 ==========
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=layer-studio-assets

# ========== RSS Feeds ==========
RSS_FEEDS_AI=https://techcrunch.com/category/artificial-intelligence/feed/,https://www.theverge.com/rss/index.xml
RSS_FEEDS_SKIN=https://www.allure.com/feed/rss
